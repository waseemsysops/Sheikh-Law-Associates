rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Cases Collection
    match /cases/{caseId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.clientUid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Appointments Collection
    match /appointments/{appointmentId} {
      allow create: if isAuthenticated() || request.resource.data.clientUid == request.auth.uid;
      allow read: if isAdmin() || (isAuthenticated() && resource.data.clientUid == request.auth.uid);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.clientUid == request.auth.uid);
    }

    // Blogs Collection
    match /blogs/{blogId} {
      allow read: if true; // Publicly readable for insights
      allow write: if isAdmin();
    }

    // Invoices Collection
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.clientUid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow create: if isAdmin();
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.clientUid == request.auth.uid);
    }

    // Documents Collection
    match /documents/{documentId} {
      allow create: if isAuthenticated() && request.resource.data.clientUid == request.auth.uid;
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.clientUid == request.auth.uid);
    }

    // Inquiries Collection
    match /inquiries/{inquiryId} {
      allow create: if true; // Public can submit contact briefs
      allow read, update, delete: if isAdmin(); // Only admins can manage inquiries
    }
  }
}
